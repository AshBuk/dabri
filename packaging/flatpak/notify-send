#!/bin/sh
# Minimal notify-send compatible wrapper for Flatpak.
set -eu

app_name="Dabri"
icon="dialog-information-symbolic"

while [ "$#" -gt 0 ]; do
    case "$1" in
        --app-name)
            app_name="$2"
            shift 2
            ;;
        --icon)
            icon="$2"
            shift 2
            ;;
        --)
            shift
            break
            ;;
        -*)
            shift
            ;;
        *)
            break
            ;;
    esac
done

summary="${1:-}"
body="${2:-}"

# Send via the desktop portal (org.freedesktop.portal.Notification) so the
# sandbox needs no direct --talk-name=org.freedesktop.Notifications hole; the
# portal is always reachable inside Flatpak. app_name is unused here — the
# portal derives the app name/icon from the installed .desktop entry.
#
# summary/body are app-controlled (error messages included), so escape
# backslash and double-quote before embedding them in the GVariant dict.
esc() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }
summary=$(esc "$summary")
body=$(esc "$body")
icon=$(esc "$icon")

# A fresh id per call yields a new notification (matching the old Notify id=0).
gdbus call --session \
    --dest org.freedesktop.portal.Desktop \
    --object-path /org/freedesktop/portal/Desktop \
    --method org.freedesktop.portal.Notification.AddNotification \
    "dabri-$(date +%s%N)" \
    "{'title': <\"$summary\">, 'body': <\"$body\">, 'icon': <('themed', <[\"$icon\"]>)>}" \
    >/dev/null
