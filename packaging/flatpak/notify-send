#!/bin/sh
# Minimal notify-send compatible wrapper for Flatpak.
set -eu

app_name="Dabri"
icon="dialog-information-symbolic"

while [ "$#" -gt 0 ]; do
    case "$1" in
        --app-name)
            app_name="$2"
            shift 2
            ;;
        --icon)
            icon="$2"
            shift 2
            ;;
        --)
            shift
            break
            ;;
        -*)
            shift
            ;;
        *)
            break
            ;;
    esac
done

summary="${1:-}"
body="${2:-}"

# Prefer the desktop portal (org.freedesktop.portal.Notification).
# Notification portal isn't provided by every compositor's portal backend
# (e.g. wlroots/Hyprland ship only ScreenCast/GlobalShortcuts), so fall back to
# the notification service directly.
esc() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }

if gdbus call --session \
    --dest org.freedesktop.portal.Desktop \
    --object-path /org/freedesktop/portal/Desktop \
    --method org.freedesktop.portal.Notification.AddNotification \
    "dabri-$(date +%s%N)" \
    "{'title': <\"$(esc "$summary")\">, 'body': <\"$(esc "$body")\">, 'icon': <('themed', <[\"$(esc "$icon")\"]>)>}" \
    >/dev/null 2>&1; then
    exit 0
fi

# Fallback: the legacy notification service. gdbus passes summary/body as literal
# positional arguments here, so they are used raw (no GVariant escaping).
exec gdbus call --session \
    --dest org.freedesktop.Notifications \
    --object-path /org/freedesktop/Notifications \
    --method org.freedesktop.Notifications.Notify \
    "$app_name" 0 "$icon" "$summary" "$body" "[]" "{}" 5000 >/dev/null
