#!/bin/sh
# Notify-send compatible wrapper for Flatpak.
set -eu

icon="dialog-information-symbolic"

while [ "$#" -gt 0 ]; do
    case "$1" in
        --app-name)
            shift 2
            ;;
        --icon)
            icon="$2"
            shift 2
            ;;
        --)
            shift
            break
            ;;
        -*)
            shift
            ;;
        *)
            break
            ;;
    esac
done

summary="${1:-}"
body="${2:-}"

# Portal-only: send via org.freedesktop.portal.Notification, which works inside
# Flatpak with no extra permission.
esc() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }

exec gdbus call --session \
    --dest org.freedesktop.portal.Desktop \
    --object-path /org/freedesktop/portal/desktop \
    --method org.freedesktop.portal.Notification.AddNotification \
    "dabri-$(date +%s%N)" \
    "{'title': <\"$(esc "$summary")\">, 'body': <\"$(esc "$body")\">, 'icon': <('themed', <[\"$(esc "$icon")\"]>)>}" \
    >/dev/null
