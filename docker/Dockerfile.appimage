# Container for building AppImage packages.
# BASE_IMAGE is overridden per arch: x86_64 stays on 22.04 (lowest glibc for
# portability, LunarG SDK provides glslc); aarch64 uses 24.04, which packages
# glslc for arm (no LunarG arm SDK exists).
ARG BASE_IMAGE=ubuntu:22.04
FROM ${BASE_IMAGE} AS builder

# Avoid timezone interaction
ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies for AppImage building
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    pkg-config \
    git \
    curl \
    libayatana-appindicator3-dev \
    libgtk-3-dev \
    libglib2.0-dev \
    libdbus-1-dev \
    ffmpeg \
    alsa-utils \
    file \
    desktop-file-utils \
    fuse \
    libfuse2 \
    xsel \
    wl-clipboard \
    xdotool \
    wtype \
    ydotool \
    libnotify-bin \
    # Vulkan runtime library (SDK installed separately for glslc + headers)
    libvulkan-dev \
    # SPIRV-Headers cmake config - required by whisper.cpp >= v1.8.5 Vulkan backend
    spirv-headers \
    && rm -rf /var/lib/apt/lists/*

# Vulkan shader compiler (glslc) + headers for whisper.cpp Vulkan backend.
ENV VULKAN_SDK_VERSION=1.3.290.0
RUN set -eux; \
    DEB_ARCH="$(dpkg --print-architecture)"; \
    if [ "$DEB_ARCH" = "amd64" ]; then \
        curl -fsSL "https://sdk.lunarg.com/sdk/download/${VULKAN_SDK_VERSION}/linux/vulkansdk-linux-x86_64-${VULKAN_SDK_VERSION}.tar.xz" -o /tmp/vulkan-sdk.tar.xz; \
        mkdir -p /opt/vulkan-sdk; \
        tar -xJf /tmp/vulkan-sdk.tar.xz -C /opt/vulkan-sdk --strip-components=1; \
        cp /opt/vulkan-sdk/x86_64/bin/glslc /usr/local/bin/; \
        cp -r /opt/vulkan-sdk/x86_64/include/vulkan /usr/include/; \
        cp -r /opt/vulkan-sdk/x86_64/include/vk_video /usr/include/; \
        rm -rf /tmp/vulkan-sdk.tar.xz /opt/vulkan-sdk; \
    else \
        apt-get update; \
        apt-get install -y --no-install-recommends glslc; \
        rm -rf /var/lib/apt/lists/*; \
    fi

# Install Go (architecture-aware: amd64 / arm64)
ARG GO_VERSION=1.25.3
ARG GO_SHA256_AMD64=0335f314b6e7bfe08c3d0cfaa7c19db961b7b99fb20be62b0a826c992ad14e0f
ARG GO_SHA256_ARM64=1d42ebc84999b5e2069f5e31b67d6fc5d67308adad3e178d5a2ee2c9ff2001f5
ENV GO_VERSION=${GO_VERSION}
RUN set -eux; \
    DEB_ARCH="$(dpkg --print-architecture)"; \
    case "$DEB_ARCH" in \
        amd64) GO_ARCH=amd64; GO_SHA="${GO_SHA256_AMD64}";; \
        arm64) GO_ARCH=arm64; GO_SHA="${GO_SHA256_ARM64}";; \
        *) echo "unsupported architecture: $DEB_ARCH"; exit 1;; \
    esac; \
    curl -fsSL "https://golang.org/dl/go${GO_VERSION}.linux-${GO_ARCH}.tar.gz" -o /tmp/go.tar.gz; \
    echo "${GO_SHA}  /tmp/go.tar.gz" | sha256sum -c -; \
    tar -C /usr/local -xzf /tmp/go.tar.gz; \
    rm -f /tmp/go.tar.gz
ENV PATH="/usr/local/go/bin:${PATH}"

# Set working directory
WORKDIR /app

# Copy project sources (better cache on go.mod/go.sum first)
COPY go.mod go.sum ./
RUN go mod download
COPY . .

# Create necessary directories
RUN mkdir -p lib sources build dist

# Set environment variables for CGO
ENV CGO_ENABLED=1
ENV C_INCLUDE_PATH="/app/lib"
ENV LIBRARY_PATH="/app/lib"
ENV CGO_CFLAGS="-I/app/lib"
ENV CGO_LDFLAGS="-L/app/lib -lwhisper -lggml-cpu -lggml"
ENV LD_LIBRARY_PATH="/app/lib"
ENV PKG_CONFIG_PATH="/app/lib"

# Optional version from build-arg
ARG APP_VERSION
ENV APP_VERSION=${APP_VERSION}

# Whisper.cpp version pin for reproducible builds
ARG WHISPER_CPP_REF=v1.9.1
ENV WHISPER_CPP_REF=${WHISPER_CPP_REF}

# Build AppImage at image build time so docker build can produce artifacts
RUN packaging/appimage/build-appimage.sh

# Export artifacts stage
FROM scratch AS artifacts
COPY --from=builder /app/dist/ /